{
  "name": "petmanager",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:frontend": "next dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "start:local": "next start --hostname 127.0.0.1 --port 3000",
    "serve:local": "npm run build && npm run start:local",
    "server:up": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-server.ps1",
    "server:down": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-local-server.ps1",
    "status:start": "node --experimental-transform-types ./scripts/job-status.ts start",
    "status:complete": "node --experimental-transform-types ./scripts/job-status.ts complete",
    "status:fail": "node --experimental-transform-types ./scripts/job-status.ts fail",
    "status:last": "node --experimental-transform-types ./scripts/job-status.ts last",
    "status:list": "node --experimental-transform-types ./scripts/job-status.ts list",
    "check:supabase-env": "node scripts/check-supabase-env-consistency.cjs",
    "check:owner-auth-guards": "node scripts/check-owner-auth-guards.cjs",
    "smoke:owner-login": "node scripts/smoke-owner-login.cjs",
    "smoke:owner-auth-recovery": "node scripts/smoke-owner-auth-recovery.cjs",
    "smoke:owner-login:with-server": "node scripts/run-owner-login-smoke-with-server.cjs",
    "test:e2e:owner-login": "playwright test tests/e2e/owner-login.spec.ts",
    "predeploy:auth": "npm run check:supabase-env && npm run check:owner-auth-guards && npm run smoke:owner-login:with-server && npm run test:e2e:owner-login",
    "predeploy": "npm run check:supabase-env && npm run check:owner-auth-guards && npm run typecheck && npm run lint && npm run build && npm run smoke:owner-login:with-server && npm run test:e2e:owner-login",
    "check:media-architecture": "node scripts/check-media-architecture.cjs",
    "media:migration-plan": "node scripts/print-media-migration-plan.cjs",
    "media:build-migration-bundle": "node scripts/build-media-migration-bundle.cjs",
    "media:schema-rest-check": "node scripts/check-media-schema-rest.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "npm --prefix backend run typecheck"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@portone/browser-sdk": "^0.1.3",
    "@portone/server-sdk": "^0.19.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
